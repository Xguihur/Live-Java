<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mtjava.livechat.mapper.RoomMemberMapper">

    <resultMap id="RoomMemberResultMap" type="com.mtjava.livechat.model.LiveRoomMember">
        <id property="id" column="id"/>
        <result property="roomId" column="room_id"/>
        <result property="userId" column="user_id"/>
        <result property="roomRole" column="room_role"/>
        <result property="joinedAt" column="joined_at"/>
    </resultMap>

    <select id="findByRoomIdAndUserId" resultMap="RoomMemberResultMap">
        SELECT id, room_id, user_id, room_role, joined_at
        FROM live_room_member
        WHERE room_id = #{roomId}
          AND user_id = #{userId}
    </select>

    <insert id="insert" parameterType="com.mtjava.livechat.model.LiveRoomMember" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO live_room_member (room_id, user_id, room_role, joined_at)
        VALUES (#{roomId}, #{userId}, #{roomRole}, #{joinedAt})
    </insert>
</mapper>

